# ============================================================================
# Says Who?  —  environment variables
# Copy to `.env.local` for local dev:  cp .env.example .env.local
# `.env*` is git-ignored. NEVER commit real keys.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# These two are safe to expose to the browser (the anon key is meant to be
# public and is protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER-ONLY. Bypasses RLS. Used by member-facing route handlers after they
# validate a group's join code. Has NO `NEXT_PUBLIC_` prefix on purpose so it
# can never reach the client bundle. Never expose or commit this.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (SERVER-ONLY) ------------------------------------------------
# Read only inside server route handlers. No NEXT_PUBLIC_ prefix => never sent
# to the browser.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- App --------------------------------------------------------------------
# Used to build shareable invite links. In production set this to your Render
# URL, e.g. https://says-who.onrender.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
